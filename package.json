{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npm run dev:api & npm run dev:web",

    "dev:api": "npm --workspace @workspace/api-server run dev",
    "dev:web": "npm --workspace @workspace/staff-app run dev",

    "build": "npm run build:api && npm run build:web",

    "build:api": "npm --workspace @workspace/api-server run build",
    "build:web": "npm --workspace @workspace/staff-app run build",

    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "typescript": "~5.9.3",
    "prettier": "^3.8.3"
  },
  "overrides": {
    "esbuild": "0.27.3"
  }
}